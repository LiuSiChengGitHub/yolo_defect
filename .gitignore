# ============================================
# YOLO Defect Detection Project .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ---------- Conda / venv ----------
env/
venv/
.conda/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Training outputs (large, regenerable) ----------
runs/
logs/
*.log

# ---------- Model weights (large) ----------
models/*.onnx
models/*.pt
saved_models/
*.pth
*.engine
*.trt

# ---------- Auto-downloaded pretrained weights (ultralytics caches these in cwd) ----------
yolov8*.pt
yolo*.pt

# ---------- SAM checkpoints (large) ----------
sam_vit_*.pth

# ---------- Docker ----------
*.tar

# ---------- Misc ----------
*.bak
*.tmp

# ============================================
# NOTE: NEU-DET dataset (~28MB) is intentionally
# tracked in git for full reproducibility.
# Clone -> run -> get results, no extra downloads.
# ============================================
