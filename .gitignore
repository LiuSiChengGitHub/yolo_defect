# ============================================
# YOLO Defect Detection Project .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ---------- Conda / venv ----------
env/
venv/
.conda/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Data (too large for GitHub) ----------
data/images/
data/labels/
data/raw/
*.zip
*.tar.gz
*.rar

# Keep data.yaml (it's small and defines dataset config)
!data/data.yaml

# ---------- Training outputs ----------
runs/
logs/
*.log

# ---------- Model weights ----------
models/*.onnx
models/*.pt
saved_models/
*.pth
*.onnx
*.pt
*.engine
*.trt

# ---------- SAM checkpoints ----------
*.pth

# ---------- Results / generated assets ----------
# Keep docs/assets/ structure but ignore large generated files
docs/assets/*.gif

# ---------- Docker ----------
*.tar

# ---------- Misc ----------
*.bak
*.tmp
